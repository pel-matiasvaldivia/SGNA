# Base
# Public URL of the app (served by nginx on port 80/443).
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=super_secret_nextauth_key_12345
# Leave empty: the browser calls the API through nginx using relative URLs
# (/api/...). The backend is NOT published to the host, only nginx is.
API_URL=
JWT_SECRET=super_secret_jwt_key_12345678901234567890

# Database
DB_USER=aeonline
DB_PASSWORD=aeonline_secret
DB_NAME=aeonline_db

# Redis
REDIS_PASSWORD=redis_secret

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_admin

# Email (2FA)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=fake_resend_key
FROM_EMAIL=noreply@auditoriasenlinea.com.ar

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# IA / MCP
ANTHROPIC_API_KEY=your_anthropic_api_key
